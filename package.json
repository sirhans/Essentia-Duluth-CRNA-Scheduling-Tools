{
  "name": "symplr-schedule",
  "version": "0.1.8",
  "description": "Desktop tool to extract scheduling data from symplr Workforce",
  "author": "Hans",
  "main": "main.js",
  "type": "commonjs",
  "scripts": {
    "start": "electron .",
    "dist:mac": "electron-builder --mac --universal --publish never",
    "dist:win": "electron-builder --win --publish never"
  },
  "license": "UNLICENSED",
  "build": {
    "appId": "com.hans.symplrschedule",
    "productName": "Essentia Duluth CRNA Scheduling Tool",
    "artifactName": "Essentia-Duluth-CRNA-Scheduling-Tool-${version}-${os}-${arch}.${ext}",
    "publish": [
      {
        "provider": "github",
        "owner": "sirhans",
        "repo": "Essentia-Duluth-CRNA-Scheduling-Tools"
      }
    ],
    "files": [
      "package.json",
      "main.js",
      "preload.js",
      "index.html",
      "renderer.js",
      "vendor/**",
      "node_modules/**"
    ],
    "directories": {
      "output": "dist-release"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "assets/icon.icns",
      "category": "public.app-category.productivity",
      "hardenedRuntime": true,
      "notarize": true
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    }
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^26.15.3"
  },
  "dependencies": {
    "electron-updater": "^6.8.9",
    "xlsx": "^0.18.5"
  }
}
